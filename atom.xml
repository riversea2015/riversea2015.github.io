&lt;li&gt;&lt;a href=&quot;https://www.jianshu.com/p/06071cba3404&quot; target=&quot;_blank&quot; rel=&quot;noopener&quot;&gt;SDWebImage源码学习笔记 ☞ SDWebImageDownloader&lt;/a&gt;&lt;/li&gt;
&lt;li&gt;&lt;a href=&quot;https://www.jianshu.com/p/e3f4a7f57899&quot; target=&quot;_blank&quot; rel=&quot;noopener&quot;&gt;SDWebImage源码学习笔记 ☞ SDImageCache&lt;/a&gt;&lt;/li&gt;&lt;/ul&gt;
    
